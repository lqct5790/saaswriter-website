---
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 h-[60px] flex items-center justify-between px-6 md:px-10
         bg-bg/70 backdrop-blur-2xl border-b border-border transition-all duration-300"
>
  <!-- Logo -->
  <a href="/" class="flex items-center gap-2 no-underline" aria-label="SaaSWriter home">
    <span
      class="w-2 h-2 rounded-full bg-green animate-pulse-dot"
      style="box-shadow: 0 0 8px #4ade80;"
      aria-hidden="true"
    ></span>
    <span class="font-display font-extrabold text-[17px] tracking-tight text-white">
      SaaSWriter
    </span>
  </a>

  <!-- Desktop nav -->
  <nav class="hidden md:flex gap-1" aria-label="Main navigation">
    <a href="#how-it-works" class="nav-link">How it works</a>
    <a href="#features" class="nav-link">Features</a>
    <a href="#early-access" class="nav-link">Pricing</a>
  </nav>

  <!-- CTA -->
  <a
    href="#hero-cta"
    class="btn-primary text-sm hidden md:inline-flex"
    aria-label="Get early access to SaaSWriter"
  >
    Get early access
  </a>

  <!-- Mobile menu button -->
  <button
    id="mobile-menu-btn"
    class="md:hidden flex flex-col gap-[5px] p-2 rounded-md hover:bg-white-6 transition-colors"
    aria-label="Toggle mobile menu"
    aria-expanded="false"
  >
    <span class="w-5 h-[1.5px] bg-white-40 block transition-all" id="m1"></span>
    <span class="w-5 h-[1.5px] bg-white-40 block transition-all" id="m2"></span>
    <span class="w-5 h-[1.5px] bg-white-40 block transition-all" id="m3"></span>
  </button>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-x-0 top-[60px] z-40 bg-surface border-b border-border
         hidden flex-col p-6 gap-2"
  aria-hidden="true"
>
  <a href="#how-it-works" class="mobile-link">How it works</a>
  <a href="#features" class="mobile-link">Features</a>
  <a href="#early-access" class="mobile-link">Pricing</a>
  <a href="#hero-cta" class="btn-primary mt-4 text-center">Get early access</a>
</div>

<style>
  .nav-link {
    @apply text-[13px] font-medium text-white-40 hover:text-white hover:bg-white-6
           px-3 py-1.5 rounded-md transition-all duration-150 no-underline;
  }
  .mobile-link {
    @apply text-[15px] font-medium text-white-40 hover:text-white
           px-3 py-2.5 rounded-md hover:bg-white-6 transition-all duration-150 no-underline;
  }
  .btn-primary {
    @apply bg-green text-black font-bold rounded-[7px] px-4 py-[7px]
           hover:bg-green-hover transition-colors duration-150 no-underline;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
    menu?.setAttribute('aria-hidden', String(isOpen));
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      menu.setAttribute('aria-hidden', 'true');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Scroll-aware header shadow
  window.addEventListener('scroll', () => {
    const header = document.getElementById('site-header');
    if (window.scrollY > 20) {
      header?.classList.add('border-white-10');
    } else {
      header?.classList.remove('border-white-10');
    }
  });
</script>
