---
const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-border mt-0">
  <div class="max-w-content mx-auto px-6 py-7 flex flex-col md:flex-row items-center justify-between gap-4">
    <!-- Logo -->
    <div class="font-display font-extrabold text-sm tracking-tight text-white-40">
      SaaSWriter
    </div>

    <!-- Copyright -->
    <p class="font-mono text-[11px] text-white-20 tracking-widest">
      © {year} SaaSWriter · saaswriter.app
    </p>

    <!-- Links -->
    <nav class="flex gap-5" aria-label="Footer links">
      <a href="/privacy" class="text-xs text-white-20 hover:text-white-40 transition-colors no-underline">Privacy</a>
      <a href="/terms" class="text-xs text-white-20 hover:text-white-40 transition-colors no-underline">Terms</a>
      <a href="mailto:hello@saaswriter.app" class="text-xs text-white-20 hover:text-white-40 transition-colors no-underline">Contact</a>
    </nav>
  </div>
</footer>
