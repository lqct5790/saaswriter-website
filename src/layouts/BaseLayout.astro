---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'SaaSWriter — The AI Copywriter Built for SaaS',
  description = 'Stop getting generic output from generic AI. SaaSWriter writes landing pages, email sequences, LinkedIn posts, case studies, and more — trained specifically for SaaS businesses.',
  ogImage = '/images/og.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="SaaSWriter" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts — non-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "SaaSWriter",
        "url": "https://saaswriter.app",
        "description": "AI copywriter agent built specifically for SaaS businesses. Writes landing pages, email sequences, LinkedIn posts, case studies, ad copy, and more.",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD",
          "description": "Free during beta"
        },
        "publisher": {
          "@type": "Organization",
          "name": "SaaSWriter",
          "url": "https://saaswriter.app"
        }
      }
    </script>

    <slot name="head" />
  </head>

  <body class="bg-bg text-white font-sans antialiased">
    <!-- Fixed background glow -->
    <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 60% 40% at 50% -5%, rgba(74,222,128,0.07) 0%, transparent 65%), radial-gradient(ellipse 30% 30% at 15% 60%, rgba(74,222,128,0.03) 0%, transparent 60%), radial-gradient(ellipse 30% 30% at 85% 40%, rgba(74,222,128,0.02) 0%, transparent 60%);"
      ></div>
    </div>

    <slot />

    <!-- Scroll animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('[data-animate]').forEach((el) => {
        const delay = el.getAttribute('data-delay') || '0';
        (el as HTMLElement).style.transitionDelay = delay + 'ms';
        observer.observe(el);
      });
    </script>

    <style is:global>
      @media (prefers-reduced-motion: reduce) {
        [data-animate] { opacity: 1 !important; transform: none !important; transition: none !important; }
      }
      [data-animate] {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      [data-animate].is-visible {
        opacity: 1;
        transform: none;
      }
    </style>
  </body>
</html>
